{
  "name": "codylab-rookie-fe",
  "version": "1.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/intesys/codylab-rookie-fe.git"
  },
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "scripts": {
    "start": "parcel src/index.html --port 3000",
    "build": "parcel build src/index.html",
    "clean": "rm -rf dist && rm -rf .parcel-cache",
    "test": "jest",
    "api:generate": "openapi-generator-cli generate --enable-post-process-file -i api.yml -t src/generated/templates/ -g typescript-axios -o src/generated/axios/",
    "api:version": "node ./scripts/api-version.js",
    "build:api": "npm run api:generate && npm run api:version",
    "postbuild": "npm run msw:install",
    "prestart": "npm run msw:install",
    "msw:install": "msw init ./dist"
  },
  "author": "Filippo Dolci",
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "5.17.1",
    "@mui/material": "5.17.1",
    "@mui/x-date-pickers": "6.20.2",
    "axios": "0.30.0",
    "dayjs": "1.11.21",
    "jest": "29.7.0",
    "notistack": "3.0.2",
    "prettier": "2.8.8",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "7.17.0",
    "react-router-dom": "7.17.0",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "2.20.2",
    "@parcel/config-default": "2.16.4",
    "@parcel/resolver-glob": "2.16.4",
    "@parcel/transformer-raw": "2.16.4",
    "@parcel/transformer-sass": "2.16.4",
    "@types/jest": "29.5.14",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/sass": "1.45.0",
    "msw": "1.3.5",
    "parcel": "2.16.4",
    "process": "0.11.10",
    "sass": "1.100.0"
  },
  "@parcel/resolver-default": {
    "packageExports": true
  },
  "msw": {
    "workerDirectory": "dist"
  },
  "volta": {
    "node": "20.13.1"
  }
}
